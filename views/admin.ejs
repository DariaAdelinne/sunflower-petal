<section class="card admin-card">
  <h1>Panou admin</h1>

  <p>Adaugă un produs nou în baza de date.</p>

  <form method="POST" action="/admin/adauga-produs" class="admin-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label for="nume">Nume produs</label>

      <input
        type="text"
        id="nume"
        name="nume"
        required
      >
    </div>

    <div class="form-group">
      <label for="pret">Preț</label>

      <input
        type="number"
        id="pret"
        name="pret"
        step="0.01"
        min="0"
        required
      >
    </div>

    <button type="submit">
      Adaugă produs
    </button>
  </form>
</section>